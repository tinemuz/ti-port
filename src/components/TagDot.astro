---
const { tags } = Astro.props;
---

<div class="flex">
  {
    tags.map((tag: string) => (
      <span class="bg-skin-bg-sub3 text-skin-text/80 flex items-center gap-1 rounded-full px-1 font-mono text-[0.45rem] leading-3 sm:px-2 sm:py-[3px] sm:text-xs sm:leading-normal">
        <div class="bg-skin-accent size-1 rounded-full sm:size-1.5" />
        <div>#{tag}</div>
      </span>
    ))
  }
</div>
