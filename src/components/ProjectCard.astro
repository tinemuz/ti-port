---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"posts">;
}

const { post } = Astro.props;
---

<div class="flex-col p-0.5 sm:p-1">
  <a href={"/posts/" + post.slug}>
    <div
      class="border-skin-border bg-skin-bg-sub relative aspect-square overflow-hidden rounded-lg border text-xs"
    >
      {/* Single Image Layout */}
      {
        post.data.images?.length === 1 && (
          <Fragment>
            <p class="absolute z-10 p-3 text-[0.65rem] text-white/50 sm:text-sm">
              {post.data.type.charAt(0).toUpperCase() + post.data.type.slice(1)}
            </p>

            <Image
              class="size-full object-cover transition-all duration-300 ease-in-out hover:scale-105 hover:grayscale"
              src={post.data.images[0].path}
              alt={post.data.images[0].alt}
              loading="eager"
            />
          </Fragment>
        )
      }
    </div>
  </a>
</div>
