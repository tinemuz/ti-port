---
const { tags } = Astro.props;
---

<div class="flex flex-wrap gap-1 sm:gap-2">
  {
    tags.map((tag: string) => (
      <span class="text-skin-text/80 bg-skin-bg-sub3 rounded-full px-1 font-mono text-[0.45rem] leading-3 sm:px-2 sm:py-[3px] sm:text-xs sm:leading-normal">
        <a href={"/tag/" + tag}>#{tag}</a>
      </span>
    ))
  }
</div>
