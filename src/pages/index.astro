---
import Featured from "../components/Featured.astro";
import MainLayout from "../layouts/main-layout.astro";
---

<MainLayout title="Tine Muzunza | Featured">
  <div class="text-skin-text flex flex-col">
    <div class="flex flex-grow flex-col items-center justify-center">
      <div class="w-full pt-6 pb-16 sm:max-w-[740px]">
        <h1 class="pb-4">
          hi i'm tine, <br /> a software engineer
        </h1>

        <p>
          Here, you'll find my process. The code, the sketches, the finished
          pieces, and the ideas that connect them. It’s a space for exploration,
          shared to help and inspire other builders and artists.
        </p>
      </div>
      <div class="w-full flex-grow sm:max-w-[740px]">
        <Featured />
      </div>
    </div>
  </div>
</MainLayout>
